{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "GVE-LEVEL.schema.json",
  "title": "GVE Level Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "specification",
    "summary",
    "definitions",
    "requirements",
    "relationships",
    "scope"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "level",
        "title",
        "version",
        "status",
        "parent"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^GVE-LEVEL-[0-9]+(?:-[A-Z0-9]+(?:-[A-Z0-9]+)*)?$"
        },
        "level": {
          "type": "integer",
          "minimum": 0
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "normative",
            "retired"
          ]
        },
        "parent": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^GVE-LEVEL-[0-9]+(?:-[A-Z0-9]+(?:-[A-Z0-9]+)*)?$"
            }
          ]
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "root",
        "imports"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "root",
            "subordinate"
          ]
        },
        "root": {
          "type": "string",
          "pattern": "^GVE-LEVEL-[0-9]+(?:-[A-Z0-9]+(?:-[A-Z0-9]+)*)?$"
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^GVE-LEVEL-[0-9]+(?:-[A-Z0-9]+(?:-[A-Z0-9]+)*)?$"
          },
          "uniqueItems": true
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "definitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/definition"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "includes",
        "excludes"
      ],
      "properties": {
        "includes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excludes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*$"
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "term",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "term": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "references"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "relation",
        "target"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "source": {
          "$ref": "#/$defs/identifier"
        },
        "relation": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "target": {
          "$ref": "#/$defs/identifier"
        }
      }
    }
  }
}
